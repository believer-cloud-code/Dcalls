rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isValidUser(data) {
      return (data.email is string || !('email' in data)) &&
             (data.displayName is string || !('displayName' in data)) &&
             (data.fcmTokens is list || !('fcmTokens' in data));
    }

    function isValidMessage(data) {
      return data.text is string &&
             (data.senderId is string || !('senderId' in data));
    }

    function isValidRecording(data) {
      return data.callId is string &&
             data.summary is string;
    }

    function isValidMemory(data) {
      return data.topic is string &&
             data.content is string;
    }

    function isValidContact(data) {
      return data.displayName is string &&
             data.phoneNumber is string;
    }

    function isCallParticipant() {
      return isAuthenticated() &&
        (request.auth.uid == resource.data.callerId ||
         request.auth.uid == resource.data.receiverId);
    }

    function isCallParticipantOnCreate() {
      return isAuthenticated() &&
        (request.auth.uid == request.resource.data.callerId ||
         request.auth.uid == request.resource.data.receiverId);
    }

    // Public profile fields readable by any signed-in user (calls, chat, E2EE keys)
    match /users/{userId} {
      allow read: if isAuthenticated();
      allow create: if isOwner(userId) && isValidUser(request.resource.data);
      allow update: if isOwner(userId) && isValidUser(request.resource.data);

      match /messages/{messageId} {
        allow read: if isOwner(userId);
        allow create, update: if isOwner(userId) && isValidMessage(request.resource.data);
      }

      match /damai_messages/{messageId} {
        allow read: if isOwner(userId);
        allow create, update: if isOwner(userId) && isValidMessage(request.resource.data);
      }

      match /calls/{callId} {
        allow read: if isOwner(userId);
        allow create, update: if isOwner(userId);
      }

      match /recordings/{recordingId} {
        allow read: if isOwner(userId);
        allow create, update: if isOwner(userId) && isValidRecording(request.resource.data);
      }

      match /ai_memory/{memoryId} {
        allow read: if isOwner(userId);
        allow create, update: if isOwner(userId) && isValidMemory(request.resource.data);
      }

      match /feedback/{feedbackId} {
        allow read: if isOwner(userId);
        allow create, update: if isOwner(userId);
      }

      match /contacts/{contactId} {
        allow read: if isOwner(userId);
        allow create, update: if isOwner(userId) && isValidContact(request.resource.data);
        allow delete: if isOwner(userId);
      }
    }

    match /calls/{callId} {
      allow read: if isAuthenticated() && isCallParticipant();
      allow create: if isAuthenticated() && isCallParticipantOnCreate();
      allow update: if isAuthenticated() && isCallParticipant();

      match /offer/{docId} {
        allow read, write: if isAuthenticated();
      }
      match /answer/{docId} {
        allow read, write: if isAuthenticated();
      }
      match /candidates/{candidateId} {
        allow read, write: if isAuthenticated();
      }
    }

    match /chats/{chatId} {
      allow read: if isAuthenticated() && request.auth.uid in resource.data.participants;
      allow create: if isAuthenticated() && request.auth.uid in request.resource.data.participants;
      allow update: if isAuthenticated() && request.auth.uid in resource.data.participants;

      match /messages/{messageId} {
        allow read: if isAuthenticated();
        allow create: if isAuthenticated() &&
          (request.auth.uid == request.resource.data.senderId ||
           request.resource.data.senderId == 'ai');
        allow update: if isAuthenticated();
      }
    }

    match /ai_feedback/{feedbackId} {
      allow read: if isAuthenticated() && request.auth.uid == resource.data.userId;
      allow create: if isAuthenticated() && request.auth.uid == request.resource.data.userId;
    }
  }
}
