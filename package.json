{
  "name": "react-example",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite --port=3000 --host=0.0.0.0",
    "sync:web": "node scripts/sync-dcalls-web.mjs",
    "build": "npm run sync:web && vite build",
    "preview": "vite preview",
    "clean": "rmdir /s /q dist",
    "lint": "tsc --noEmit",
    "electron:dev": "concurrently \"npm run dev\" \"wait-on http://localhost:3000 && electron .\"",
    "electron:build": "npm run build && electron-builder",
    "build:electron": "electron-builder",
    "cap:sync": "npm run build && npx cap sync",
    "cap:open:android": "npx cap open android",
    "android:build": "npm run build && npx cap sync && npx cap open android"
  },
  "build": {
    "appId": "com.app.communication",
    "productName": "CommunicationApp",
    "directories": {
      "output": "dist-electron"
    },
    "files": [
      "dist/**/*",
      "electron/**/*"
    ],
    "win": {
      "target": "nsis"
    },
    "mac": {
      "target": "dmg"
    },
    "linux": {
      "target": "AppImage"
    }
  },
  "dependencies": {
    "@capacitor/android": "^7.6.5",
    "@capacitor/cli": "^7.6.5",
    "@capacitor/core": "^7.6.5",
    "@capacitor/preferences": "^7.0.4",
    "@google/genai": "^1.29.0",
    "better-sqlite3": "^12.4.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "dotenv": "^17.2.3",
    "express": "^4.21.2",
    "firebase": "^12.13.0",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-markdown": "^10.1.0",
    "react-native": "^0.85.3",
    "react-phone-input-2": "^2.15.1",
    "react-router-dom": "^7.13.1",
    "remark-gfm": "^4.0.1",
    "tailwind-merge": "^3.5.0"
  },
  "devDependencies": {
    "@react-native-community/cli": "v20.1.3",
    "@react-native/metro-config": "^0.76.0",
    "@tailwindcss/vite": "^4.3.0",
    "@types/express": "^4.17.21",
    "@types/node": "^22.14.0",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.21",
    "concurrently": "^9.2.1",
    "electron": "^41.0.2",
    "electron-builder": "^26.8.1",
    "tailwindcss": "^4.3.0",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.4.2",
    "wait-on": "^9.0.4"
  }
}
