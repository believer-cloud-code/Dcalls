{
  "firestore": {
    "database": "default",
    "location": "africa-south1",
    "rules": "firestore.rules",
    "indexes": "firestore.indexes.json"
  },
  "auth": {
    "providers": {
      "anonymous": true,
      "emailPassword": true,
      "googleSignIn": {
        "oAuthBrandDisplayName": " Dcalls",
        "supportEmail": "dcallsapp@gmail.com"
      }
    }
  },
  "hosting": {
    "public": "dist",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ],
    "rewrites": [
      { "source": "/welcome.html", "destination": "/welcome.html" },
      { "source": "/help.html", "destination": "/help.html" },
      { "source": "/damai.html", "destination": "/damai.html" },
      { "source": "/teams.html", "destination": "/teams.html" },
      { "source": "/dcalls-config.js", "destination": "/dcalls-config.js" },
      { "source": "**", "destination": "/index.html" }
    ],
    "headers": [
      {
        "source": "/dcalls-config.js",
        "headers": [{ "key": "Cache-Control", "value": "no-cache" }]
      }
    ]
  },
  "database": {
    "rules": "database.rules.json"
  },
  "emulators": {
    "dataconnect": {
      "dataDir": "dataconnect/.dataconnect/pgliteData"
    },
    "auth": {
      "port": 9099
    },
    "firestore": {
      "port": 8080
    },
    "database": {
      "port": 9000
    },
    "hosting": {
      "port": 5000
    },
    "ui": {
      "enabled": true
    },
    "singleProjectMode": true
  },
  "dataconnect": {
    "source": "dataconnect"
  },
  "functions": [
    {
      "codebase": "default",
      "disallowLegacyRuntimeConfig": true,
      "predeploy": [
        "npm --prefix \"$RESOURCE_DIR\" run lint",
        "npm --prefix \"$RESOURCE_DIR\" run build"
      ],
      "source": "functions",
      "ignore": [
        "node_modules",
        ".git",
        "firebase-debug.log",
        "firebase-debug.*.log",
        "*.local"
      ]
    }
  ],
  "remoteconfig": {
    "template": "remoteconfig.template.json"
  },
  "extensions": {}
}
